# =============================================================================
# mini-shanebrain — Multi-Platform Social Bot
# Copy to .env and fill in your credentials
# =============================================================================

# --- AI Backend ---
USE_OLLAMA=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=shanebrain-3b
ANTHROPIC_API_KEY=your_claude_api_key

# --- Personality (who the bot writes as) ---
PAGE_PERSONALITY=Shane Brazelton from Hazel Green, Alabama. Dispatch coordinator at SRM Concrete. Father of five sons. Builder of ShaneBrain AI on a Raspberry Pi. ADHD brain who turns hyperfocus into projects. Sober since November 2023. Faith-driven, family-first, direct and warm. Topics: everyday life, fatherhood, work ethic, small-town Alabama, sobriety journey, building things with tech, faith, lessons learned the hard way.

# --- Weaviate RAG (optional, enriches posts with knowledge base context) ---
WEAVIATE_URL=http://localhost:8080

# --- Platform Toggles (set true + add credentials) ---
POST_TO_FACEBOOK=true
POST_TO_INSTAGRAM=false
POST_TO_LINKEDIN=false
POST_TO_X=false
POST_TO_THREADS=false
POST_TO_BLUESKY=false

# --- Facebook --- (Graph API page token)
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_ACCESS_TOKEN=your_page_access_token
FB_APP_ID=your_app_id
FB_APP_SECRET=your_app_secret

# --- Instagram --- (requires image URL for every post)
INSTAGRAM_USER_ID=
INSTAGRAM_DEFAULT_IMAGE_URL=https://example.com/your-brand-image.jpg

# --- LinkedIn --- (get from linkedin.com/developers, token expires 60 days)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID

# --- X (Twitter) --- (get from developer.x.com, free tier: 500 posts/month)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Threads --- (Meta OAuth flow, token expires 60 days)
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Bluesky --- (create app password at bsky.app Settings > App Passwords)
BSKY_HANDLE=yourname.bsky.social
BSKY_APP_PASSWORD=

# --- Schedules (optional, per-platform cron overrides) ---
# Default schedules are built-in if not set:
#   facebook:  2x/day (8am, 5pm)
#   instagram: 1x/day (noon)
#   linkedin:  3x/week (Mon/Wed/Fri 9am)
#   x:         3x/day (7am, noon, 6pm)
#   threads:   2x/day (10am, 4pm)
#   bluesky:   1x/day (2pm)
# SCHEDULE_FACEBOOK=0 8,17 * * *
# SCHEDULE_X=0 7,12,18 * * *

# Global fallback schedule (used if no per-platform schedule set)
POST_SCHEDULE=0 9,14,19 * * *
