# Database
DATABASE_URL=postgresql+asyncpg://claimcruncher:claimcruncher@localhost:5433/claimcruncher
DATABASE_URL_SYNC=postgresql://claimcruncher:claimcruncher@localhost:5433/claimcruncher
POSTGRES_USER=claimcruncher
POSTGRES_PASSWORD=claimcruncher
POSTGRES_DB=claimcruncher

# Redis
REDIS_URL=redis://localhost:6380/0

# MinIO (S3-compatible local storage)
MINIO_ROOT_USER=claimcruncher
MINIO_ROOT_PASSWORD=claimcruncher123
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=claim-documents
S3_ACCESS_KEY=claimcruncher
S3_SECRET_KEY=claimcruncher123

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OCR
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_CLOUD_PROVIDER=none
# OCR_CLOUD_PROVIDER=document_ai
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# DOCUMENT_AI_PROCESSOR_ID=
# OCR_CLOUD_PROVIDER=textract
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Cruncher AI (Claude API)
ANTHROPIC_API_KEY=
CRUNCHER_MODEL=claude-sonnet-4-6
CRUNCHER_FLAG_MODEL=claude-haiku-4-5-20251001

# App
APP_NAME=Claim Cruncher
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
